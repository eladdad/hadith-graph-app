        <mxCell id="lOqWJcGC6gH-27NqQ_Zj-52" parent="1" style="whiteSpace=wrap;html=1;fontSize=25;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;" value="&lt;span style=&quot;white-space: normal;&quot;&gt;الترمذي&lt;/span&gt;" vertex="1">
