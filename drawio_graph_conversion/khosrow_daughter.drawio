        <mxCell id="lOqWJcGC6gH-27NqQ_Zj-92" parent="1" style="whiteSpace=wrap;html=1;fontSize=20;strokeColor=none;align=right;fillColor=none;" value="أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى ، قَال : حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ ، قَال : حَدَّثَنَا حُمَيْدٌ ، عَنِ الْحَسَنِ ، عَنْ أَبِي بَكْرَةَ ، قَالَ :&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(51, 255, 51));&quot;&gt;عَصَمَنِي اللَّهُ بِشَيْءٍ سَمِعْتُهُ&lt;/font&gt; مِنْ رَسُولِ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ لَمَّا هَلَكَ &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 51, 51));&quot;&gt;كِسْرَى&lt;/font&gt; ، قَالَ :&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&quot; مَنِ اسْتَخْلَفُوا ؟ قَالَ : ابِنْتُهُ ، قَالَ : لَنْ يُفْلِحَ قَوْمٌ &lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 153, 51));&quot;&gt;وَلَّوْا&lt;/font&gt; أَمْرَهُمُ امْرَأَةً &quot;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="260" x="3669.5299999999997" y="1760" as="geometry" />
        </mxCell>
        <mxCell id="lOqWJcGC6gH-27NqQ_Zj-93" parent="1" style="whiteSpace=wrap;html=1;fontSize=25;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;" value="&lt;span style=&quot;white-space: normal;&quot;&gt;الدولابي&lt;/span&gt;" vertex="1">
